{
  "name": "airbnb-api",
  "version": "1.0.0",
  "type": "module",
  "description": "Airbnb Listings API - in-memory learning project",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "postinstall": "npm run db:generate && npm run build",
    "start": "node dist/src/index.js",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:seed-coordinates": "tsx prisma/scripts/seed-listing-coordinates.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate && npm run db:link-client",
    "db:link-client": "node -e \"const fs=require('fs');const p=require('path');const t=p.join(process.cwd(),'node_modules','@prisma','client','.prisma');if(!fs.existsSync(t)){fs.mkdirSync(p.dirname(t),{recursive:true});fs.symlinkSync(p.join('..','..','.prisma'),t,'dir');console.log('linked',t);}else{console.log('link-exists',t);}\"",
    "db:fresh": "prisma migrate reset",
    "migrate": "prisma migrate deploy"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.14",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.14",
    "prisma": "7.8.0",
    "tsx": "^4.16.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@langchain/core": "^1.1.42",
    "@langchain/groq": "^1.2.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.3.5",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "prisma": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/adapter-pg": "7.8.0"
  }
}