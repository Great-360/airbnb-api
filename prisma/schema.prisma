generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HOST
  GUEST
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  password         String?
  role             Role      @default(GUEST)
  avatar           String?
  avatarPublicId   String?
  bio              String?
  isSuperhost      Boolean   @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  listings         Listing[]
  bookings         Booking[]
  reviews          Review[]
  wishlist         Wishlist[]
  profile          Profile?

  @@index([name])
  @@index([role])
}


model Profile {
  id      String  @id @default(uuid())
  bio     String?
  website String?
  country String?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String  @unique
}

model Listing {
  id            String         @id @default(uuid())
  title         String
  description   String
  location      String
  latitude      Float?
  longitude     Float?
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String[]
  rating        Float?
  reviewCount   Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  host          User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  hostId        String
  bookings      Booking[]
  photos        ListingPhoto[]
  reviews       Review[]
  wishlist      Wishlist[]

  @@index([location])
  @@index([type])
  @@index([pricePerNight])
  @@index([hostId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}


model ListingPhoto {
  id        String  @id @default(uuid())
  url       String
  publicId  String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
}

model Booking {
  id                   String        @id @default(uuid())
  checkIn              DateTime
  checkOut             DateTime
  totalPrice           Float
  status               BookingStatus @default(PENDING)
  messagingEnabled     Boolean       @default(true)
  createdAt            DateTime      @default(now())
  guest                User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  guestId              String
  listing              Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId            String

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
}

